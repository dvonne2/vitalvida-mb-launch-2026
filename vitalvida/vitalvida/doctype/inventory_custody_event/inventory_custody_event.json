   "in_list_view": 1
  },
  {
   "fieldname": "event_type",
   "fieldtype": "Select",
   "label": "Event Type",
   "options": "INVENTORY_RECEIVED\nINVENTORY_TRANSFERRED\nINVENTORY_DELIVERED\nINVENTORY_COUNTED\nINVENTORY_RECONCILED\nINVENTORY_WRITTEN_OFF\nINVENTORY_REVERSED",
   "reqd": 1,
   "in_list_view": 1
  },
  {
