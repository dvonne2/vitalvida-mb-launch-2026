   "fieldtype": "Select",
   "label": "Status",
   "options": "Recorded\nPosted\nReversed\nException",
   "default": "Recorded",
   "reqd": 1
  },
  {
   "fieldname": "occurred_at",
   "fieldtype": "Datetime",
   "label": "Occurred At",
   "reqd": 1
  },
  {
   "fieldname": "source_doctype",
   "fieldtype": "Data",
   "label": "Source DocType"
  },
  {
   "fieldname": "source_name",
   "fieldtype": "Data",
   "label": "Source Name"
  },
  {
   "fieldname": "consequence_doctype",
   "fieldtype": "Data",
   "label": "ERPNext Consequence DocType"
  },
  {
   "fieldname": "consequence_name",
   "fieldtype": "Dynamic Link",
   "options": "consequence_doctype",
   "label": "ERPNext Consequence"
  },
  {
   "fieldname": "reversal_of",
   "fieldtype": "Link",
   "options": "Inventory Custody Event",
   "label": "Reversal Of"
