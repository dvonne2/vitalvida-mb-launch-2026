{
 "doctype": "DocType",
 "name": "Commission Earning Event",
 "module": "Vitalvida",
 "engine": "InnoDB",
 "naming_rule": "Expression",
 "autoname": "format:CEE-{YYYY}-{#####}",
 "field_order": ["employee", "employee_name", "source_doctype", "source_reference",
                 "earning_type", "rule_version", "inputs_json", "amount",
                 "period", "status", "earned_at", "idempotency_key",
                 "reversal_of", "manager_validated_by", "hr_reviewed_by",
                 "finance_approved_by", "payroll_run_ref",
                 "consequence_doctype", "consequence_name", "consequence_posted"],
 "fields": [
  {"fieldname": "employee", "fieldtype": "Link", "options": "VV Employee",
   "label": "Employee", "reqd": 1, "in_list_view": 1,
   "description": "VV Employee today; remaps to HRMS Employee at HRMS adoption"},
  {"fieldname": "employee_name", "fieldtype": "Data", "label": "Employee Name", "read_only": 1},
  {"fieldname": "source_doctype", "fieldtype": "Data", "label": "Source DocType", "reqd": 1},
  {"fieldname": "source_reference", "fieldtype": "Data", "label": "Source Reference",
   "reqd": 1, "search_index": 1},
  {"fieldname": "earning_type", "fieldtype": "Select", "label": "Earning Type", "reqd": 1,
   "options": "Telesales\nDPSR\nUpsell\nRevival\nRecovery\nChampion Bonus\nOther",
   "in_list_view": 1},
  {"fieldname": "rule_version", "fieldtype": "Link", "options": "Incentive Rule Version",
   "label": "Rule Version", "reqd": 1},
  {"fieldname": "inputs_json", "fieldtype": "Long Text", "label": "Inputs Snapshot (JSON)",
   "description": "Reproducibility: the exact inputs the rule saw"},
  {"fieldname": "amount", "fieldtype": "Currency", "label": "Amount", "reqd": 1, "in_list_view": 1},
  {"fieldname": "period", "fieldtype": "Data", "label": "Period", "reqd": 1,
   "description": "e.g. 2026-W28 or 2026-07"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "reqd": 1, "in_list_view": 1,
   "options": "Earned\nApproved\nPosted\nReversed", "default": "Earned"},
  {"fieldname": "earned_at", "fieldtype": "Datetime", "label": "Earned At", "reqd": 1},
  {"fieldname": "idempotency_key", "fieldtype": "Data", "label": "Idempotency Key",
   "reqd": 1, "unique": 1, "read_only": 1, "no_copy": 1},
  {"fieldname": "reversal_of", "fieldtype": "Link", "options": "Commission Earning Event",
   "label": "Reversal Of"},
  {"fieldname": "manager_validated_by", "fieldtype": "Link", "options": "User",
   "label": "Manager Validated By", "read_only": 1},
  {"fieldname": "hr_reviewed_by", "fieldtype": "Link", "options": "User",
   "label": "HR Reviewed By", "read_only": 1},
  {"fieldname": "finance_approved_by", "fieldtype": "Link", "options": "User",
   "label": "Finance Approved By", "read_only": 1},
  {"fieldname": "payroll_run_ref", "fieldtype": "Link", "options": "Payroll Run Event",
   "label": "Payroll Run", "read_only": 1},
  {"fieldname": "consequence_doctype", "fieldtype": "Data", "label": "Consequence DocType", "read_only": 1},
  {"fieldname": "consequence_name", "fieldtype": "Data", "label": "Consequence", "read_only": 1,
   "description": "Journal Entry today; Additional Salary after HRMS adoption"},
  {"fieldname": "consequence_posted", "fieldtype": "Check", "label": "Consequence Posted", "read_only": 1, "default": "0"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "create": 1, "write": 1},
  {"role": "HR Manager", "read": 1, "write": 1},
  {"role": "Accounts Manager", "read": 1, "write": 1},
  {"role": "Accounts User", "read": 1}
 ]
}
