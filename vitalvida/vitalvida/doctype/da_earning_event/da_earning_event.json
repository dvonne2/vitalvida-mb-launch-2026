{
 "doctype": "DocType",
 "name": "DA Earning Event",
 "module": "Vitalvida",
 "engine": "InnoDB",
 "naming_rule": "Expression",
 "autoname": "format:DAE-{YYYY}-{#####}",
 "field_order": ["delivery_agent", "supplier", "source_order", "earning_type",
                 "qualifying_event", "qualifying_event_ref", "fee_rule_version",
                 "amount", "status", "earned_at", "idempotency_key",
                 "reversal_of", "settlement_batch", "erpnext_payable_ref",
                 "consequence_doctype", "consequence_name", "consequence_posted"],
 "fields": [
  {"fieldname": "delivery_agent", "fieldtype": "Link", "options": "Delivery Agent",
   "label": "Delivery Agent", "reqd": 1, "in_list_view": 1},
  {"fieldname": "supplier", "fieldtype": "Link", "options": "Supplier",
   "label": "Supplier (payable party, R41)", "reqd": 1},
  {"fieldname": "source_order", "fieldtype": "Data", "label": "Source Order", "reqd": 1,
   "search_index": 1, "description": "VV Order / Sales Order name that qualified"},
  {"fieldname": "earning_type", "fieldtype": "Select", "label": "Earning Type",
   "options": "Delivery Fee\nBonus", "reqd": 1, "in_list_view": 1},
  {"fieldname": "qualifying_event", "fieldtype": "Data", "label": "Qualifying Event",
   "reqd": 1, "description": "e.g. vv.order.closed (R39: Order Closed)"},
  {"fieldname": "qualifying_event_ref", "fieldtype": "Data", "label": "Qualifying Event Ref"},
  {"fieldname": "fee_rule_version", "fieldtype": "Link", "options": "Incentive Rule Version",
   "label": "Fee Rule Version", "reqd": 1},
  {"fieldname": "amount", "fieldtype": "Currency", "label": "Amount", "reqd": 1, "in_list_view": 1},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "reqd": 1,
   "options": "Earned\nBatched\nPaid\nReversed", "default": "Earned", "in_list_view": 1},
  {"fieldname": "earned_at", "fieldtype": "Datetime", "label": "Earned At", "reqd": 1},
  {"fieldname": "idempotency_key", "fieldtype": "Data", "label": "Idempotency Key",
   "reqd": 1, "unique": 1, "read_only": 1, "no_copy": 1},
  {"fieldname": "reversal_of", "fieldtype": "Link", "options": "DA Earning Event",
   "label": "Reversal Of"},
  {"fieldname": "settlement_batch", "fieldtype": "Link", "options": "Settlement Batch",
   "label": "Settlement Batch", "read_only": 1},
  {"fieldname": "erpnext_payable_ref", "fieldtype": "Link", "options": "Purchase Invoice",
   "label": "Purchase Invoice", "read_only": 1},
  {"fieldname": "consequence_doctype", "fieldtype": "Data", "label": "Consequence DocType", "read_only": 1},
  {"fieldname": "consequence_name", "fieldtype": "Data", "label": "Consequence", "read_only": 1},
  {"fieldname": "consequence_posted", "fieldtype": "Check", "label": "Consequence Posted", "read_only": 1, "default": "0"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "create": 1},
  {"role": "Accounts Manager", "read": 1},
  {"role": "Accounts User", "read": 1}
 ]
}
